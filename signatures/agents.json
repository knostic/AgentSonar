{
  "version": "2026-01-22",
  "agents": [
    {
      "name": "Cursor",
      "process": "cursor",
      "domains": ["*.anthropic.com", "*.openai.com", "*.cursor.sh"]
    },
    {
      "name": "GitHub Copilot",
      "process": "code",
      "domains": ["*.github.com", "*.openai.com", "*.githubcopilot.com"]
    },
    {
      "name": "Claude Code",
      "process": "claude",
      "domains": ["*.anthropic.com"]
    },
    {
      "name": "Windsurf",
      "process": "windsurf",
      "domains": ["*.windsurf.ai", "*.anthropic.com", "*.openai.com"]
    },
    {
      "name": "Codeium",
      "process": "codeium",
      "domains": ["*.codeium.com"]
    },
    {
      "name": "Tabnine",
      "process": "tabnine",
      "domains": ["*.tabnine.com"]
    },
    {
      "name": "Continue",
      "process": "continue",
      "domains": ["*.anthropic.com", "*.openai.com"]
    },
    {
      "name": "Aider",
      "process": "aider",
      "domains": ["*.anthropic.com", "*.openai.com"]
    },
    {
      "name": "Ollama",
      "process": "ollama",
      "domains": ["*.ollama.ai", "*.ollama.com"]
    }
  ],
  "ai_domains": [
    "anthropic.com",
    "openai.com",
    "mistral.ai",
    "cohere.ai",
    "ai21.com",
    "groq.com",
    "perplexity.ai",
    "deepseek.com",
    "together.ai",
    "fireworks.ai",
    "replicate.com",
    "huggingface.co"
  ],
  "ignore": [
    {"process": "*", "domain": "*.cloudflare.com"},
    {"process": "*", "domain": "*.cloudflare-dns.com"},
    {"process": "*", "domain": "*.amazonaws.com"},
    {"process": "*", "domain": "*.akamai.com"},
    {"process": "*", "domain": "*.fastly.com"}
  ]
}
